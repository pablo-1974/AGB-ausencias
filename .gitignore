.DS_Store
Thumbs.db

# ----------------------------
# Configuración / Credenciales
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# Alembic (mantener migraciones)
# ----------------------------
# No ignores alembic/versions/*.py (¡se deben versionar!)
alembic/versions/__pycache__/

# ----------------------------
# Reportes / Exportaciones
# ----------------------------
# PDFs generados por la app (parte diario / mensual)
reports/
reports_daily/
reports_monthly/
exports/
generated/
output/
**/output/*.pdf
**/reports/*.pdf
**/exports/*.pdf

# Si prefieres ignorar cualquier PDF suelto fuera de static:
*.pdf
# ...pero permite PDFs fijos en static (si tuvieras alguno):
!static/*.pdf

# ----------------------------
# Datos locales / SQLite opcional
# ----------------------------
sqlite.db
*.sqlite3

# ----------------------------
# Node (por si en el futuro añades build de frontend)
# ----------------------------
node_modules/
*.map

# ----------------------------
# Docker (opcional)
# ----------------------------
docker-data/
*.pid
